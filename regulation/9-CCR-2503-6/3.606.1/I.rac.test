- name: grant_amount_is_chart_grant_minus_countable_income
  period: "2026-04-02"
  input:
    countable_gross_earned_income_after_disregards: 250
    countable_unearned_income: 100
    number_of_children_in_assistance_unit: 0
    number_of_caretakers_in_assistance_unit: 2
  output:
    basic_cash_assistance_grant_amount: 153
- name: grant_amount_handles_zero_unearned_income
  period: "2026-04-02"
  input:
    countable_gross_earned_income_after_disregards: 150
    countable_unearned_income: 0
    number_of_children_in_assistance_unit: 0
    number_of_caretakers_in_assistance_unit: 2
  output:
